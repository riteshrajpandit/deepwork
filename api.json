    "transport": "WebSocket",
    "channels": [
      {
        "name": "notifications",
        "path": "/ws/notifications",
        "events": [
          "notification.created",
          "notification.read"
        ]
      },
      {
        "name": "discussion_messages",
        "path": "/ws/discussions/{discussion_id}",
        "events": [
          "message.created",
          "typing.started",
          "typing.stopped"
        ]
      },
      {
        "name": "project_board",
        "path": "/ws/projects/{project_id}/board",
        "events": [
          "task.created",
          "task.updated",
          "task.moved",
          "task.archived"
        ]
      }
    ]
  },
